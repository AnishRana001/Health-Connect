# ─────────────────────────────────────────────────────────────
# Health Connect — Backend Environment Variables (Example)
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# On Render → Service → Environment tab.

# Server
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/healthconnect?retryWrites=true&w=majority

# JWT — use a long random secret in production
JWT_SECRET=replace_with_a_very_long_random_secret_string

# Frontend URL (your Vercel deployment URL — no trailing slash)
# Used by Socket.IO CORS and Express CORS
CLIENT_URL=https://your-vercel-app.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
